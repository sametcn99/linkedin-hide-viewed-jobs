{
  "name": "linkedin-hide-viewed-jobs",
  "description": "A userscript that automatically hides viewed job postings in LinkedIn Jobs.",
  "version": "1.1.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:extension": "bun run scripts/build-extension.ts",
    "build:all": "bun run build && bun run build:extension",
    "package:chrome": "bun run scripts/package-extension.ts chrome",
    "package:firefox": "bun run scripts/package-extension.ts firefox",
    "package:all": "bun run scripts/package-extension.ts",
    "release": "bun run scripts/release.ts",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"**/*.md\"",
    "check": "bun run lint:fix && bun run format"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sametcn99/linkedin-hide-viewed-jobs.git"
  },
  "keywords": [],
  "author": "sametcn99",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sametcn99/linkedin-hide-viewed-jobs/issues"
  },
  "homepage": "https://github.com/sametcn99/linkedin-hide-viewed-jobs#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.43",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-monkey": "^8.0.6"
  }
}
