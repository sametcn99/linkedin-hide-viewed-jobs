{
  "manifest_version": 3,
  "name": "LinkedIn Hide Viewed Jobs",
  "description": "Hides viewed job cards on LinkedIn Jobs pages, adds a compact badge, and lets you reveal hidden items anytime.",
  "permissions": ["storage", "activeTab", "tabs", "windows"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png",
    "192": "icons/android-chrome-192x192.png",
    "512": "icons/android-chrome-512x512.png"
  }
}